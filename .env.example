# =============================================================================
# FreeSites Generator — required environment variables
# Copy to .env for local development (never commit .env)
# =============================================================================

# Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=

# Claude generation settings (optional — defaults shown)
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8000

# Prompt templates directory (optional — defaults to src/prompts)
# Override in production if templates live outside the default path.
PROMPTS_DIR=

# Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs for the two plan tiers in your Stripe account.
STRIPE_FOUNDING_PRICE_ID=
STRIPE_STANDARD_PRICE_ID=

# Where to send the customer after successful payment / cancellation.
STRIPE_SUCCESS_URL=https://freesites.io/onboarding/success
STRIPE_CANCEL_URL=https://freesites.io/onboarding/cancel

# Beta access -------------------------------------------------------------
# Share this code with beta clients. If empty, no betaCode will ever validate.
# Must be a strong random string — it is the only gate to bypassing payment.
BETA_CODE=

# Resend (Stage 4+) -------------------------------------------------------
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@freesites.io

# Portal auth (Stage 5+) --------------------------------------------------
# PORTAL_JWT_SECRET=

# Netlify Blobs (auto-configured in Netlify deployments) ------------------
# Required for local development only — obtain from Netlify CLI:
#   netlify dev  (sets NETLIFY_BLOBS_CONTEXT automatically)
# NETLIFY_BLOBS_CONTEXT=
